<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/top_tab_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:background="@color/primaryColor"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tabIndicatorColor="@color/white"
        app:tabIndicatorHeight="5dp"
        app:tabSelectedTextColor="@color/white"
        app:tabTextColor="#80FFFFFF">

        <com.google.android.material.tabs.TabItem
            android:id="@+id/tab_todays_pick"
            android:text="Today's Pick"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content" />

        <com.google.android.material.tabs.TabItem
            android:id="@+id/tab_modules"
            android:text="Modules"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content" />

        <com.google.android.material.tabs.TabItem
            android:id="@+id/tab_resources"
            android:text="Resources"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content" />

    </com.google.android.material.tabs.TabLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/sub_tab_layout_modules"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="108dp"
        android:background="@color/SubTabColor"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tabIndicatorColor="@color/primaryColor"
        app:tabIndicatorHeight="4dp"
        app:tabSelectedTextColor="@color/white"
        app:tabTextColor="#80FFFFFF">

        <com.google.android.material.tabs.TabItem
            android:id="@+id/tab_basic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Basic" />

        <com.google.android.material.tabs.TabItem
            android:id="@+id/tab_intermediate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Intermediate" />

        <com.google.android.material.tabs.TabItem
            android:id="@+id/tab_advanced"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Advanced" />

    </com.google.android.material.tabs.TabLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager_modules"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="160dp"
        app:layout_constraintTop_toBottomOf="@id/sub_tab_layout_modules"
        app:layout_constraintBottom_toBottomOf="parent" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/sub_tab_layout_resources"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="108dp"
        android:background="@color/SubTabColor"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tabIndicatorColor="@color/primaryColor"
        app:tabIndicatorHeight="4dp"
        app:tabSelectedTextColor="@color/white"
        app:tabTextColor="#80FFFFFF">

        <com.google.android.material.tabs.TabItem
            android:id="@+id/tab_articles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Articles" />

        <com.google.android.material.tabs.TabItem
            android:id="@+id/tab_reports"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reports" />

        <com.google.android.material.tabs.TabItem
            android:id="@+id/tab_toolkits"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Toolkits" />

    </com.google.android.material.tabs.TabLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager_resources"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="160dp"
        app:layout_constraintTop_toBottomOf="@id/sub_tab_layout_resources"
        app:layout_constraintBottom_toBottomOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>